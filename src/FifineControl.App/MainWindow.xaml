<Window x:Class="FifineControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FifineControl" Width="1120" Height="760" MinWidth="920" MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="FifineControl" FontSize="27" FontWeight="SemiBold" />
                <TextBlock Text="Controle local dos endpoints de áudio do Windows" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="{StaticResource SuccessBrush}" Margin="0,0,7,0" />
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0,12,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" MinWidth="420" />
                    <ColumnDefinition Width="*" MinWidth="360" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <TextBlock Text="Microfone" FontSize="18" FontWeight="SemiBold" />
                                <Button Content="Atualizar" Command="{Binding RefreshDevicesCommand}" Style="{StaticResource SecondaryButton}" DockPanel.Dock="Right" Margin="8,0,0,0" />
                            </DockPanel>
                            <TextBlock Text="Endpoint de captura" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5" />
                            <ComboBox ItemsSource="{Binding CaptureDevices}" SelectedItem="{Binding SelectedCaptureDevice}" DisplayMemberPath="Name" Margin="0,0,0,15" />

                            <Grid Margin="0,0,0,9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Volume do endpoint (Windows)" />
                                <TextBlock Grid.Column="1" Text="{Binding EndpointVolumePercent, StringFormat={}{0:0}%}" Foreground="{StaticResource MutedTextBrush}" />
                            </Grid>
                            <Slider Minimum="0" Maximum="100" Value="{Binding EndpointVolumePercent, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,13" />

                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nível em tempo real" />
                                <TextBlock Grid.Column="1" Text="{Binding PeakPercent, StringFormat={}{0:0.0}%}" Foreground="{StaticResource MutedTextBrush}" />
                            </Grid>
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding PeakPercent, Mode=OneWay}" Margin="0,0,0,15" />

                            <Grid Margin="0,0,0,9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Ganho digital da rota" />
                                    <TextBlock Text="É aplicado ao áudio processado; não altera o ganho físico do SC3." FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding DigitalGainDb, StringFormat={}{0:+0.0;-0.0;0.0} dB}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                            </Grid>
                            <Slider Minimum="-24" Maximum="24" Value="{Binding DigitalGainDb}" TickFrequency="1" Margin="0,0,0,16" />

                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding MuteButtonText}" Command="{Binding ToggleMuteCommand}" MinWidth="120" />
                                <TextBlock Text="{Binding MuteStateText}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="5,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Gravação WAV" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />
                            <TextBlock Text="Diretório de destino" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5" />
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding RecordingDirectory}" IsReadOnly="True" />
                                <Button Grid.Column="1" Content="Escolher…" Command="{Binding BrowseRecordingDirectoryCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="{Binding RecordingButtonText}" Command="{Binding ToggleRecordingCommand}" MinWidth="150" />
                                <TextBlock Grid.Column="1" Text="{Binding RecordingElapsed}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <Button Grid.Column="2" Content="Abrir pasta" Command="{Binding OpenRecordingFolderCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Perfil" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />
                            <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfileName}" Margin="0,0,0,10" />
                            <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Aplicar" Command="{Binding ApplyProfileCommand}" />
                                <Button Content="Salvar estado atual" Command="{Binding SaveProfileCommand}" Style="{StaticResource SecondaryButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Roteamento DSP" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="Destino WASAPI. Para Discord/OBS, prefira CABLE Input ou uma entrada virtual do VoiceMeeter. Em saídas físicas, use fones e volume baixo." TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10" />
                            <ComboBox ItemsSource="{Binding RenderDevices}" SelectedItem="{Binding SelectedMonitorDevice}" DisplayMemberPath="Name" Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Gate" />
                                <CheckBox Grid.Column="1" Content="Bypass" IsChecked="{Binding GateBypassed}" />
                            </Grid>
                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="-80" Maximum="-5" Value="{Binding GateThresholdDb}" />
                                <TextBlock Grid.Column="1" Text="{Binding GateThresholdDb, StringFormat={}{0:0} dB}" Foreground="{StaticResource MutedTextBrush}" Margin="10,0,0,0" />
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Compressor" />
                                <CheckBox Grid.Column="1" Content="Bypass" IsChecked="{Binding CompressorBypassed}" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="-60" Maximum="0" Value="{Binding CompressorThresholdDb}" />
                                <TextBlock Grid.Column="1" Text="{Binding CompressorThresholdDb, StringFormat={}{0:0} dB}" Foreground="{StaticResource MutedTextBrush}" Margin="10,0,0,0" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="1" Maximum="20" Value="{Binding CompressorRatio}" />
                                <TextBlock Grid.Column="1" Text="{Binding CompressorRatio, StringFormat={}{0:0.0}:1}" Foreground="{StaticResource MutedTextBrush}" Margin="10,0,0,0" />
                            </Grid>
                            <TextBlock Text="EQ de 3 bandas" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding EqPresets}" SelectedItem="{Binding SelectedEqPreset}" Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Antes do DSP" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding RoutingPrePeakPercent, StringFormat={}{0:0.0}%}" Foreground="{StaticResource MutedTextBrush}" />
                            </Grid>
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding RoutingPrePeakPercent, Mode=OneWay}" Margin="0,0,0,7" />
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Depois do DSP" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding RoutingPostPeakPercent, StringFormat={}{0:0.0}%}" Foreground="{StaticResource MutedTextBrush}" />
                            </Grid>
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding RoutingPostPeakPercent, Mode=OneWay}" Margin="0,0,0,10" />
                            <Button Content="{Binding RoutingButtonText}" Command="{Binding ToggleRoutingCommand}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding RoutingStatusText}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="OBS Studio" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="OBS WebSocket 5.x (padrao: porta 4455)" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10" />
                            <TextBlock Text="Servidor" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5" />
                            <TextBox Text="{Binding ObsServerUri, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,9" />
                            <TextBlock Text="Senha" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5" />
                            <PasswordBox x:Name="ObsPasswordBox" PasswordChanged="ObsPasswordBox_OnPasswordChanged" Margin="0,0,0,9" />
                            <CheckBox Content="Conectar ao iniciar" IsChecked="{Binding ObsConnectOnStartup}" Margin="0,0,0,9" />
                            <TextBlock Text="{Binding ObsStatusText}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding ObsConnectionButtonText}" Command="{Binding ToggleObsConnectionCommand}" MinWidth="105" />
                                <Button Content="Iniciar gravacao" Command="{Binding StartObsRecordingCommand}" Style="{StaticResource SecondaryButton}" />
                                <Button Content="Parar" Command="{Binding StopObsRecordingCommand}" Style="{StaticResource SecondaryButton}" />
                            </StackPanel>
                            <TextBlock Text="{Binding ObsRecordingStateText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding HotkeyStatusText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="Gravações recentes" FontSize="18" FontWeight="SemiBold" />
                                <Button Content="Recarregar" Command="{Binding RefreshRecentCommand}" Style="{StaticResource SecondaryButton}" DockPanel.Dock="Right" Margin="8,0,0,0" />
                            </DockPanel>
                            <ListBox ItemsSource="{Binding RecentRecordings}" SelectedItem="{Binding SelectedRecording}" Background="Transparent" BorderThickness="0" MaxHeight="190">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding CreatedText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding SizeText}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBox Text="{Binding RecordingNewName, UpdateSourceTrigger=PropertyChanged}" Margin="0,9,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                                <Button Content="Abrir" Command="{Binding OpenSelectedRecordingCommand}" Style="{StaticResource SecondaryButton}" />
                                <Button Content="Renomear" Command="{Binding RenameSelectedRecordingCommand}" Style="{StaticResource SecondaryButton}" />
                                <Button Content="Mover para Lixeira" Command="{Binding DeleteSelectedRecordingCommand}" Style="{StaticResource SecondaryButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Diagnóstico" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding DiagnosticSummary}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" MaxHeight="75" />
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Copiar diagnóstico" Command="{Binding CopyDiagnosticsCommand}" Style="{StaticResource SecondaryButton}" />
                                <Button Content="Abrir logs" Command="{Binding OpenLogsCommand}" Style="{StaticResource SecondaryButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#171A23" Padding="24,10">
            <Grid>
                <TextBlock Text="{Binding LastMessage}" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <CheckBox Content="Iniciar com o Windows" IsChecked="{Binding RunAtStartup}" Margin="0,0,18,0" />
                    <CheckBox Content="Minimizar para a bandeja" IsChecked="{Binding MinimizeToTray}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
